# Frontend Environment Variables for Vercel Deployment

# Backend API URL (your Render backend URL)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Better Auth URL (same as API URL for auth endpoints)
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-backend.onrender.com

# Database URL (for Better Auth SSR)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Better Auth Secret (must match backend)
BETTER_AUTH_SECRET=your-secret-key
